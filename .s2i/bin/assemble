#!/bin/bash
set -e

# S2I builder puts the source code in /tmp/src initially.
# We must copy it to the destination directory (/opt/app-root/src).
if [ -d /tmp/src ]; then
  echo "---> Copying application source..."
  cp -Rf /tmp/src/. /opt/app-root/src/
fi

cd /opt/app-root/src

echo "---> Installing admin dependencies..."
npm install --prefix admin --production=false

echo "---> Installing server dependencies..."
npm install --prefix server --production=false

echo "---> Building server (TypeScript)..."
npm run build --prefix server

echo "---> Building admin (Vite)..."
npm run build --prefix admin

echo "---> Verifying admin build output..."
if [ -d "/opt/app-root/src/public/admin/assets" ]; then
  echo "Admin assets found:"
  ls -lh /opt/app-root/src/public/admin/assets/
else
  echo "ERROR: /opt/app-root/src/public/admin/assets does NOT exist after build!"
  echo "Contents of /opt/app-root/src/public/:"
  ls -la /opt/app-root/src/public/ || echo "(public/ directory missing)"
  exit 1
fi

echo "---> Setting directory permissions for runtime storage..."

# Public data dir (markers.json, uploads/)
mkdir -p /opt/app-root/src/server/storage/uploads

# Private config dir (settings, logs, status, colors) — never served publicly
mkdir -p /opt/app-root/src/server/storage/config

# OpenShift runs containers with a random UID in group 0.
# We must give group write permissions to both directories.
chown -R 1001:0 /opt/app-root/src/server/storage
chmod -R g+rwx /opt/app-root/src/server/storage

echo "---> Build complete."
