#!/bin/bash
set -e

# S2I builder puts the source code in /tmp/src initially.
# We must copy it to the destination directory (/opt/app-root/src).
if [ -d /tmp/src ]; then
  echo "---> Copying application source..."
  cp -Rf /tmp/src/. /opt/app-root/src/
fi

cd /opt/app-root/src

echo "---> Installing dependencies and building..."

# Install root deps (including devDependencies like concurrently)
npm install --production=false

# Also ensure sub-packages install devDependencies for building
# We modify the root build script dynamically by telling npm not to prune devDependencies
export NODE_ENV=development

# Build server (TypeScript) + admin (Vite)
npm run build

echo "---> Setting directory permissions for runtime storage..."
# Ensure the storage directory exists
mkdir -p /opt/app-root/src/server/storage

# OpenShift runs containers with a random UID in group 0.
# We must give group write permissions to the storage directory.
chown -R 1001:0 /opt/app-root/src/server/storage
chmod -R g+rwx /opt/app-root/src/server/storage

echo "---> Build complete."
